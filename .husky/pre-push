#!/bin/sh

# ─────────────────────────────────────────────────────────────
# PRE-PUSH HOOK
# Runs on: every `git push`
# Speed:   Slower — runs full checks across the monorepo
#
# What it does (in order, stops on first failure):
#   1. Type-check  →  pnpm turbo run type-check
#   2. Tests       →  pnpm turbo run test
#   3. Build       →  pnpm turbo run build
#
# If any step fails, the push is blocked with a clear message.
# ─────────────────────────────────────────────────────────────

echo ""
echo "🚀 Pre-push checks starting..."
echo ""

# ── Step 1: Type checking ─────────────────────────────────────
echo "🔎 [1/3] Running type-check across all packages..."
pnpm turbo run type-check

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Push blocked — type-check failed."
  echo "   Run 'pnpm type-check' to see the errors."
  echo ""
  exit 1
fi

echo "✅ Type-check passed."
echo ""

# ── Step 2: Tests ─────────────────────────────────────────────
echo "🧪 [2/3] Running tests across all packages..."
pnpm turbo run test

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Push blocked — tests failed."
  echo "   Run 'pnpm test' to see which tests are failing."
  echo ""
  exit 1
fi

echo "✅ Tests passed."
echo ""

# ── Step 3: Build ─────────────────────────────────────────────
echo "🏗️  [3/3] Building all packages..."
pnpm turbo run build

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Push blocked — build failed."
  echo "   Run 'pnpm build' to reproduce the build error."
  echo ""
  exit 1
fi

echo "✅ Build passed."
echo ""

echo "🎉 All pre-push checks passed — pushing to remote!"
echo ""
