#!/bin/sh

# ─────────────────────────────────────────────────────────────
# PRE-COMMIT HOOK
# Runs on: every `git commit`
# Speed:   Fast — operates only on staged files via lint-staged
#
# What it does:
#   1. ESLint --fix  →  auto-fixes lint errors per workspace package
#   2. Prettier      →  auto-formats all staged file types
#
# If any step cannot be auto-fixed, the commit is blocked.
# ─────────────────────────────────────────────────────────────

echo ""
echo "🔍 Pre-commit: linting & formatting staged files..."
echo ""

pnpm lint-staged --allow-empty

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit failed — lint or format errors could not be auto-fixed."
  echo "   Please fix the remaining errors manually and stage the changes."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-commit passed — all staged files are clean!"
echo ""
